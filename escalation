// ============================================================
// ESCALATION.GS
// Handles form submissions from the BSI Escalation Guide.
// Functions called via google.script.run from EscalationGuide HTML.
//
// REQUIRED SCRIPT PROPERTIES (set via Project Settings → Properties):
//   ESCALATION_SHEET_ID  — ID of the Google Sheet to log issues
//   SLACK_WEBHOOK_URL    — Slack incoming webhook URL for notifications
//
// OPTIONAL SCRIPT PROPERTIES:
//   ESCALATION_TAB_NAME  — Sheet tab name (default: "Escalation Log")
// ============================================================

const ESCALATION_DRAFT_KEY = 'ESCALATION_DRAFT';

const ESCALATION_HEADERS = [
  'Customer Name', 'PMREO Link', 'Spreadsheet Link',
  'Database Link', 'Issue Type', 'Object Type', 'Description',
  'Screenshots', 'Submitted By', 'Timestamp', 'Status'
];


/**
 * Step 1: Saves form data to Script Properties.
 * Called by the HTML form before submitEscalation() to avoid
 * google.script.run argument serialization issues in modals.
 */
function saveEscalationDraft(
  customerName, pmreoLink, spreadsheetLink, databaseLink,
  issueType, objectType, description, screenshots, timestamp
) {
  const draft = {
    customerName:    String(customerName    || '').trim(),
    pmreoLink:       String(pmreoLink       || '').trim(),
    spreadsheetLink: String(spreadsheetLink || '').trim(),
    databaseLink:    String(databaseLink    || '').trim(),
    issueType:       String(issueType       || '').trim(),
    objectType:      String(objectType      || '').trim(),
    description:     String(description     || '').trim(),
    screenshots:     String(screenshots     || 'N/A').trim(),
    timestamp:       String(timestamp       || new Date().toISOString()),
    status:          'New'
  };

  PropertiesService.getScriptProperties()
    .setProperty(ESCALATION_DRAFT_KEY, JSON.stringify(draft));
}


/**
 * Step 2: Reads the saved draft, appends it to the escalation log
 * Google Sheet (one value per column), then sends a Slack notification.
 *
 * Throws on missing configuration so the HTML can surface the error.
 */
function submitEscalation() {
  const props = PropertiesService.getScriptProperties();

  // ── Read & parse the draft ──────────────────────────────────
  const raw = props.getProperty(ESCALATION_DRAFT_KEY);
  if (!raw) {
    throw new Error('No escalation draft found. Please fill out the form again.');
  }

  let data;
  try {
    data = JSON.parse(raw);
  } catch (e) {
    throw new Error('Could not read escalation draft: ' + e.message);
  }

  // ── Resolve target sheet ────────────────────────────────────
  const sheetId = props.getProperty('ESCALATION_SHEET_ID');
  if (!sheetId) {
    throw new Error(
      'ESCALATION_SHEET_ID is not set. ' +
      'Go to Apps Script → Project Settings → Script Properties and add it.'
    );
  }

  const tabName = props.getProperty('ESCALATION_TAB_NAME') || 'Escalation Log';
  const ss      = SpreadsheetApp.openById(sheetId);
  let   sheet   = ss.getSheetByName(tabName);

  // Auto-create the tab with bold headers if it doesn't exist yet
  if (!sheet) {
    sheet = ss.insertSheet(tabName);
    sheet.appendRow(ESCALATION_HEADERS);
    sheet.getRange(1, 1, 1, ESCALATION_HEADERS.length)
      .setFontWeight('bold')
      .setBackground('#f3f3f3');
  }

  const submittedBy = Session.getActiveUser().getEmail();

  // ── Append one row — each value in its own column ──────────
  // ORDER must match ESCALATION_HEADERS above.
  sheet.appendRow([
    data.customerName,
    data.pmreoLink,
    data.spreadsheetLink,
    data.databaseLink,
    data.issueType,
    data.objectType,
    data.description,
    data.screenshots,
    submittedBy,
    data.timestamp,
    data.status
  ]);

  // ── Send Slack notification (non-fatal if it fails) ─────────
  const webhookUrl = props.getProperty('SLACK_WEBHOOK_URL');
  if (webhookUrl) {
    _sendSlackEscalation(webhookUrl, data, submittedBy);
  }

  // Clean up the draft so stale data can't be resubmitted
  props.deleteProperty(ESCALATION_DRAFT_KEY);
}


/**
 * Sends a formatted Block Kit message to Slack for a new escalation.
 * Failures are logged but do NOT throw — a Slack hiccup should never
 * block the sheet write from being confirmed to the user.
 *
 * @param {string} webhookUrl   — Slack incoming webhook URL
 * @param {Object} data         — Parsed escalation draft object
 * @param {string} submittedBy  — Email of the submitter
 */
function _sendSlackEscalation(webhookUrl, data, submittedBy) {
  const payload = {
    customerName:    data.customerName,
    pmreoLink:       data.pmreoLink,
    spreadsheetLink: data.spreadsheetLink,
    databaseLink:    data.databaseLink,
    issueType:       data.issueType,
    objectType:      data.objectType,
    description:     data.description,
    screenshots:     data.screenshots,
    submittedBy:     submittedBy,
    timestamp:       data.timestamp,
    status:          data.status
  };

  try {
    UrlFetchApp.fetch(webhookUrl, {
      method:             'post',
      contentType:        'application/json',
      payload:            JSON.stringify(payload),
      muteHttpExceptions: true
    });
  } catch (e) {
    console.error('Slack notification failed: ' + e.message);
  }
}
